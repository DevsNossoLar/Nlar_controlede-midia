{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./*": {
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs",
      "default": "./dist/*.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/*.tsx --format esm --dts --clean --external react,react-dom",
    "dev": "tsup src/*.tsx --format esm --dts --watch --external react,react-dom",
    "lint": "eslint . --max-warnings 0",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
